# Squad: ignore runtime state (logs, inbox, sessions)
# Note: .squad/casting/* is identity and MUST be committed to main, not ignored
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/.cache/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Compiled ARM output from 'az bicep build'
infra/main.json
infra/integration-account/ia-content.json
infra/integration-account/ia-content-supplier.json
infra/compute/logicapp-bundle.json
